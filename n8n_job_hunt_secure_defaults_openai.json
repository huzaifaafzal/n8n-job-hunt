      "parameters": {
        "operation": "append",
        "sheetId": "={{$item(0).$node['Workflow Config'].json.trackerSheetId}}",
        "range": "={{$item(0).$node['Workflow Config'].json.trackerSheetName}}",
        "columns": {
          "mappingMode": "defineBelow",
          "value": [
            {
              "column": "job_post_link",
              "value": "={{$item(0).$node['If Relevant?'].json.link || $item(0).$node['If Relevant?'].json.jobUrl || ''}}"
            },
            {
              "column": "title",
              "value": "={{$item(0).$node['If Relevant?'].json.title || ''}}"
            },
            {
              "column": "seniority_level",
              "value": "={{$item(0).$node['If Relevant?'].json.seniorityLevel || ''}}"
            },
            {
              "column": "posted_at",
              "value": "={{$item(0).$node['If Relevant?'].json.postedAt || ''}}"
            },
            {
              "column": "company_name",
              "value": "={{$item(0).$node['If Relevant?'].json.companyName || ''}}"
            },
            {
              "column": "website",
              "value": "={{$item(0).$node['If Relevant?'].json.companyWebsite || ''}}"
            },
            {
              "column": "salary",
              "value": "={{$item(0).$node['If Relevant?'].json.salary || ''}}"
            },
            {
              "column": "description",
              "value": "={{$item(0).$node['If Relevant?'].json.descriptionText || ''}}"
            },
            {
              "column": "applicants_count",
              "value": "={{$item(0).$node['If Relevant?'].json.applicantsCount || ''}}"
            },
            {
              "column": "resume_url",
              "value": "={{$json.resumeUrl}}"
            },
            {
              "column": "application_url",
              "value": "={{$item(0).$node['If Relevant?'].json.applyUrl || ''}}"
            }
          ]
        }
      },
      "credentials": {
        "googleSheetsOAuth2Api": {
          "id": "REPLACE",
          "name": "Google Sheets account"
        }
      },
      "notesInFlow": true,
      "notes": "Uses the same tracker idea as the transcript: job post link, title, seniority, posted at, company, website, salary, description, applicants, resume URL, application URL."
    },
